{{!
    @template local_unifiedgrader/feedback_view

    Student read-only feedback view with annotated PDF and grade/feedback display.

    Context variables required:
    - cmid: Course module ID
    - activityname: Activity name
    - activityurl: URL to the activity
    - gradedisplay: Formatted grade string (e.g. "85 / 100")
    - feedback: HTML feedback text
    - hasfeedback: Whether feedback text exists
    - selectedfileid: Currently selected file ID
    - selectedfileurl: Preview URL of the selected PDF (annotated if available)
    - selectedfilename: Filename of the selected PDF
    - pdffiles: Array of PDF files
    - hasmultiplefiles: Whether there are multiple PDF files
    - pdffilesjson: JSON-encoded array of PDF files
    - hasannotatedpdf: Whether an annotated PDF exists for the selected file
    - annotatedpdfurl: URL of the annotated PDF (for download)
    - annotatedpdfmapjson: JSON map of fileid to annotated PDF URL
    - userid: Current student user ID
    - hasfeedbackfiles: Whether there are feedback files to display
    - feedbackfiles: Array of feedback file objects (filename, filesize, url, iconurl)
    - hascommentsfeature: Whether submission comments plugin is enabled
    - commentcount: Number of existing submission comments
    - canpostcomments: Whether the student can post comments
    - showrightcolumn: Whether to show the right column (feedback or comments)
}}
<div class="local-unifiedgrader-feedback" data-region="feedback-viewer"
     data-cmid="{{cmid}}" data-fileid="{{selectedfileid}}"
     data-pdfurl="{{selectedfileurl}}" data-pdffiles="{{pdffilesjson}}"
     data-annotatedpdfmap="{{annotatedpdfmapjson}}">

    {{! Header bar with back button, activity name, grade badge }}
    <div class="d-flex align-items-center justify-content-between border-bottom py-2 px-3 mb-3">
        <div class="d-flex align-items-center gap-2">
            <a href="{{activityurl}}" class="btn btn-sm btn-outline-secondary"
               title="{{#str}} backtocourse, local_unifiedgrader {{/str}}">
                <i class="fa fa-arrow-left" aria-hidden="true"></i>
            </a>
            <h5 class="mb-0">{{activityname}}</h5>
        </div>
        <div class="d-flex align-items-center gap-2">
            {{#hasannotatedpdf}}
                <a href="{{annotatedpdfurl}}" class="btn btn-sm btn-outline-primary" download>
                    <i class="fa fa-download me-1" aria-hidden="true"></i>
                    {{#str}} download_annotated_pdf, local_unifiedgrader {{/str}}
                </a>
            {{/hasannotatedpdf}}
            {{#gradedisplay}}
                <span class="badge bg-primary fs-6">
                    {{#str}} grade, local_unifiedgrader {{/str}}: {{gradedisplay}}
                </span>
            {{/gradedisplay}}
        </div>
    </div>

    <div class="row g-3 px-3">
        {{! Left: PDF viewer (read-only) }}
        <div class="{{#showrightcolumn}}col-lg-8{{/showrightcolumn}}{{^showrightcolumn}}col-12{{/showrightcolumn}}">
            {{! File selector for multiple PDFs }}
            {{#hasmultiplefiles}}
                <div class="mb-2">
                    <select data-action="file-selector" class="form-select form-select-sm">
                        {{#pdffiles}}
                            <option value="{{fileid}}" data-url="{{previewurl}}"
                                    {{#selected}}selected{{/selected}}>
                                {{filename}}
                            </option>
                        {{/pdffiles}}
                    </select>
                </div>
            {{/hasmultiplefiles}}

            {{! PDF viewer with read-only annotation layer }}
            <div data-region="pdf-viewer-wrapper"
                 style="height: calc(100vh - 200px); border: 1px solid var(--bs-border-color, #dee2e6); border-radius: 0.375rem; overflow: hidden;">
                <div data-region="pdf-viewer-component" data-readonly="1">
                    {{> local_unifiedgrader/pdf_viewer }}
                </div>
            </div>
        </div>

        {{! Right: Feedback + submission comments panel }}
        {{#showrightcolumn}}
            <div class="col-lg-4">
                {{#hasfeedback}}
                    <div class="card">
                        <div class="card-header py-2">
                            <h6 class="mb-0">
                                <i class="fa fa-comment-o me-1" aria-hidden="true"></i>
                                {{#str}} feedback, local_unifiedgrader {{/str}}
                            </h6>
                        </div>
                        <div class="card-body" style="max-height: calc(100vh - 250px); overflow-y: auto;">
                            {{{feedback}}}
                        </div>
                    </div>
                {{/hasfeedback}}

                {{#hasfeedbackfiles}}
                    <div class="card {{#hasfeedback}}mt-3{{/hasfeedback}}">
                        <div class="card-header py-2">
                            <h6 class="mb-0">
                                <i class="fa fa-files-o me-1" aria-hidden="true"></i>
                                {{#str}} feedbackfiles, local_unifiedgrader {{/str}}
                            </h6>
                        </div>
                        <div class="card-body p-0">
                            <ul class="list-group list-group-flush">
                                {{#feedbackfiles}}
                                    <li class="list-group-item d-flex align-items-center gap-2 py-2">
                                        <img src="{{iconurl}}" alt="" width="24" height="24" class="flex-shrink-0">
                                        <div class="flex-grow-1 text-truncate">
                                            <a href="{{url}}" class="text-truncate d-block">{{filename}}</a>
                                            <small class="text-muted">{{filesize}}</small>
                                        </div>
                                        <a href="{{url}}" class="btn btn-sm btn-outline-secondary flex-shrink-0"
                                           title="{{#str}} download {{/str}}">
                                            <i class="fa fa-download" aria-hidden="true"></i>
                                        </a>
                                    </li>
                                {{/feedbackfiles}}
                            </ul>
                        </div>
                    </div>
                {{/hasfeedbackfiles}}

                {{#hascommentsfeature}}
                    <div class="card {{#hasfeedback}}mt-3{{/hasfeedback}}{{^hasfeedback}}{{#hasfeedbackfiles}}mt-3{{/hasfeedbackfiles}}{{/hasfeedback}}"
                         data-region="feedback-comments"
                         data-cmid="{{cmid}}"
                         data-userid="{{userid}}">
                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">
                                <i class="fa fa-comments me-1" aria-hidden="true"></i>
                                {{#str}} submissioncomments, local_unifiedgrader {{/str}}
                            </h6>
                            {{#commentcount}}
                                <span class="badge bg-secondary" data-region="comment-count-badge">{{commentcount}}</span>
                            {{/commentcount}}
                        </div>
                        <div data-region="comments-list" class="card-body p-3"
                             style="max-height: 400px; overflow-y: auto;">
                            <div class="text-center text-muted py-3">
                                <div class="spinner-border spinner-border-sm" role="status"></div>
                            </div>
                        </div>
                        {{#canpostcomments}}
                            <div class="card-footer py-2" data-region="comments-form">
                                <div class="d-flex gap-2 align-items-end">
                                    <input type="text" data-region="comment-input"
                                           class="form-control form-control-sm rounded-pill"
                                           placeholder="{{#str}} addcomment, local_unifiedgrader {{/str}}">
                                    <button type="button" data-action="post-comment"
                                            class="btn btn-primary btn-sm rounded-circle
                                                   d-flex align-items-center justify-content-center"
                                            style="width: 32px; height: 32px; flex-shrink: 0;" disabled>
                                        <i class="fa fa-paper-plane" style="font-size: 0.75rem;"></i>
                                    </button>
                                </div>
                            </div>
                        {{/canpostcomments}}
                    </div>
                {{/hascommentsfeature}}
            </div>
        {{/showrightcolumn}}
    </div>
</div>

{{#js}}
    require(['local_unifiedgrader/feedback_viewer'], function(FeedbackViewer) {
        FeedbackViewer.init();
    });
    {{#hascommentsfeature}}
    require(['local_unifiedgrader/feedback_comments'], function(FeedbackComments) {
        FeedbackComments.init({{cmid}}, {{userid}});
    });
    {{/hascommentsfeature}}
{{/js}}
