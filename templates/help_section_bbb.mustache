<h4>Required configuration recap</h4>
<table class="table table-sm table-bordered">
    <thead><tr><th>Where</th><th>Setting</th><th>Why</th></tr></thead>
    <tbody>
        <tr><td>Moodle admin</td><td><code>local_unifiedgrader/enable_bigbluebuttonbn</code></td><td>Routes BBB activities through the unified grader</td></tr>
        <tr><td>Moodle admin</td><td><code>mod_bigbluebuttonbn/meetingevents_enabled</code> (<em>Register live sessions</em>)</td><td>Tells the BBB server where to POST analytics callbacks</td></tr>
        <tr><td>BBB server</td><td><code>defaultKeepEvents=true</code> in <code>bbb-web.properties</code></td><td>Server keeps the raw events needed to generate the callback payload</td></tr>
        <tr><td>BBB server</td><td>Reachable from Moodle host (HTTP/S)</td><td>Recording metadata + statistics page fetch</td></tr>
    </tbody>
</table>
</section>
