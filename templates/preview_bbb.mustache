{{!
    @template local_unifiedgrader/preview_bbb

    BigBlueButton submission preview rendered into the preview-pane iframe
    via preview_submission.php.

    Renders (in order):
      1. A recording switcher (only when more than one recording exists),
      2. The active recording embedded as an iframe to BBB's playback wrapper,
      3. An "Activity Points" stats card with the five engagement metrics
         plus aggregated session duration,
      4. A "Did not attend" empty state when there is neither a recording
         nor any engagement summary log for the user.

    Example context (json):
    {
        "recordings": [
            {"recordingid": 12, "name": "Session 1",
             "playbackurl": "https://moodle.example.com/mod/bigbluebuttonbn/bbb_view.php?action=play&bn=1&rid=12&rtype=presentation",
             "starttime": 1709128800, "endtime": 1709132400, "groupid": 0,
             "sessionlabel": "Friday, 28 February 2026, 10:00 AM"}
        ],
        "hasrecordings": true,
        "hasmultiplerecordings": false,
        "activerecordingurl": "https://moodle.example.com/mod/bigbluebuttonbn/bbb_view.php?action=play&bn=1&rid=12&rtype=presentation",
        "activitypoints": {
            "chats": 4, "talks": 12, "raisehand": 2, "pollvotes": 3,
            "emojis": 1, "duration": 3540, "durationformatted": "59m",
            "sessioncount": 1
        },
        "hasattended": true
    }
}}
<div data-region="bbb-preview" class="d-flex flex-column gap-3">

{{#hasrecordings}}
    <div class="d-flex align-items-center gap-2 flex-wrap">
        {{#hasmultiplerecordings}}
        <div data-region="bbb-recording-switcher" class="btn-group btn-group-sm flex-wrap" role="tablist"
             aria-label="{{#str}} bbb_recording_switcher, local_unifiedgrader {{/str}}">
            <button type="button"
                    class="btn btn-outline-secondary{{#isaggregate}} active{{/isaggregate}}"
                    data-recordingref=""
                    data-action="bbb-show-aggregate"
                    aria-selected="{{#isaggregate}}true{{/isaggregate}}{{^isaggregate}}false{{/isaggregate}}">
                {{#str}} bbb_all_sessions, local_unifiedgrader {{/str}}
            </button>
            {{#recordings}}
            <button type="button"
                    class="btn btn-outline-secondary{{#isactive}} active{{/isactive}}"
                    data-recording-url="{{playbackurl}}"
                    data-recording-id="{{recordingid}}"
                    data-recordingref="{{bbbrecordingid}}"
                    aria-selected="{{#isactive}}true{{/isactive}}{{^isactive}}false{{/isactive}}">
                {{sessionlabel}}
            </button>
            {{/recordings}}
        </div>
        {{/hasmultiplerecordings}}

        <div class="ms-auto btn-group btn-group-sm" role="group">
            <button type="button"
                    class="btn btn-sm btn-outline-secondary"
                    data-action="bbb-recording-fullscreen"
                    title="{{#str}} bbb_recording_fullscreen, local_unifiedgrader {{/str}}">
                <i class="fa fa-expand" aria-hidden="true"></i>
                <span class="ms-1 d-none d-md-inline">{{#str}} bbb_recording_fullscreen, local_unifiedgrader {{/str}}</span>
            </button>
            <a class="btn btn-sm btn-outline-secondary"
               href="{{activerecordingurl}}"
               target="_blank"
               rel="noopener"
               title="{{#str}} bbb_recording_newtab, local_unifiedgrader {{/str}}">
                <i class="fa fa-external-link" aria-hidden="true"></i>
                <span class="ms-1 d-none d-md-inline">{{#str}} bbb_recording_newtab, local_unifiedgrader {{/str}}</span>
            </a>
        </div>
    </div>

    {{#hasoverlay}}
        {{{overlayhtml}}}
    {{/hasoverlay}}
    {{^hasoverlay}}
    <div class="ratio ratio-16x9 border rounded">
        <iframe data-region="bbb-recording-iframe"
                class="w-100 h-100 border-0"
                src="{{activerecordingurl}}"
                allow="autoplay; fullscreen; encrypted-media"
                allowfullscreen
                title="{{#str}} bbb_recording_iframe_title, local_unifiedgrader {{/str}}">
        </iframe>
    </div>
    {{/hasoverlay}}
{{/hasrecordings}}

{{#hassummary}}
    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
                <h5 class="card-title mb-0">
                    {{#str}} bbb_activitypoints_heading, local_unifiedgrader {{/str}}
                    <small class="text-muted">
                        ({{#str}} bbb_session_count, local_unifiedgrader, {{activitypoints.sessioncount}} {{/str}})
                    </small>
                </h5>
                {{#hasstatisticslinks}}
                    {{#singlestatisticsurl}}
                    <a href="{{singlestatisticsurl}}" target="_blank" rel="noopener"
                       class="btn btn-sm btn-outline-secondary"
                       title="{{#str}} bbb_view_full_analytics_help, local_unifiedgrader {{/str}}">
                        <i class="fa fa-external-link me-1" aria-hidden="true"></i>
                        {{#str}} bbb_view_full_analytics, local_unifiedgrader {{/str}}
                    </a>
                    {{/singlestatisticsurl}}
                    {{^singlestatisticsurl}}
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                title="{{#str}} bbb_view_full_analytics_help, local_unifiedgrader {{/str}}">
                            <i class="fa fa-external-link me-1" aria-hidden="true"></i>
                            {{#str}} bbb_view_full_analytics, local_unifiedgrader {{/str}}
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            {{#statisticslinks}}
                            <li>
                                <a class="dropdown-item" href="{{url}}" target="_blank" rel="noopener">
                                    {{sessionlabel}}
                                </a>
                            </li>
                            {{/statisticslinks}}
                        </ul>
                    </div>
                    {{/singlestatisticsurl}}
                {{/hasstatisticslinks}}
            </div>
            {{! Aggregate (all sessions) tiles — visible by default. Switcher
                JS toggles visibility between this block and the per-session
                blocks below when the teacher selects an individual recording. }}
            <div data-region="bbb-tiles-aggregate" class="{{^showaggregatetiles}}d-none{{/showaggregatetiles}}">
                {{#activitypoints.hasactivityscore}}
                <div class="alert alert-info py-2 px-3 mb-2 d-flex align-items-center justify-content-between">
                    <div>
                        <strong>{{#str}} bbb_activity_score, local_unifiedgrader {{/str}}</strong>
                        <span class="ms-2 text-muted small">
                            {{#str}} bbb_activity_score_avg_help, local_unifiedgrader {{/str}}
                        </span>
                    </div>
                    <span class="badge bg-primary fs-6">{{activitypoints.activityscoreformatted}} / 10</span>
                </div>
                {{/activitypoints.hasactivityscore}}
                <div class="row g-2 text-center">
                    <div class="col-6 col-md-4 col-lg">
                        <div class="border rounded p-2 h-100">
                            <div class="h4 mb-0">{{activitypoints.chats}}</div>
                            <div class="small text-muted">{{#str}} bbb_metric_chats, local_unifiedgrader {{/str}}</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg">
                        <div class="border rounded p-2 h-100">
                            <div class="h4 mb-0">{{activitypoints.talks}}</div>
                            <div class="small text-muted">{{#str}} bbb_metric_talks, local_unifiedgrader {{/str}}</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg">
                        <div class="border rounded p-2 h-100">
                            <div class="h4 mb-0">{{activitypoints.raisehand}}</div>
                            <div class="small text-muted">{{#str}} bbb_metric_raisehand, local_unifiedgrader {{/str}}</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg">
                        <div class="border rounded p-2 h-100">
                            <div class="h4 mb-0">{{activitypoints.pollvotes}}</div>
                            <div class="small text-muted">{{#str}} bbb_metric_pollvotes, local_unifiedgrader {{/str}}</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg">
                        <div class="border rounded p-2 h-100">
                            <div class="h4 mb-0">{{activitypoints.emojis}}</div>
                            <div class="small text-muted">{{#str}} bbb_metric_emojis, local_unifiedgrader {{/str}}</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg">
                        <div class="border rounded p-2 h-100">
                            <div class="h4 mb-0">{{activitypoints.durationformatted}}</div>
                            <div class="small text-muted">{{#str}} bbb_metric_duration, local_unifiedgrader {{/str}}</div>
                        </div>
                    </div>
                </div>
            </div>

            {{#activitypoints.sessions}}
            <div data-region="bbb-tiles-session" data-recordingref="{{recordingref}}" class="{{^isactive}}d-none{{/isactive}}">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="small text-muted">
                        {{#str}} bbb_session_label_prefix, local_unifiedgrader {{/str}} {{sessionlabel}}
                    </div>
                    {{#hasactivityscore}}
                    <span class="badge bg-primary">{{activityscoreformatted}} / 10</span>
                    {{/hasactivityscore}}
                </div>
                <div class="row g-2 text-center">
                    <div class="col-6 col-md-4 col-lg">
                        <div class="border rounded p-2 h-100">
                            <div class="h4 mb-0">{{chats}}</div>
                            <div class="small text-muted">{{#str}} bbb_metric_chats, local_unifiedgrader {{/str}}</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg">
                        <div class="border rounded p-2 h-100">
                            <div class="h4 mb-0">{{talks}}</div>
                            <div class="small text-muted">{{#str}} bbb_metric_talks, local_unifiedgrader {{/str}}</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg">
                        <div class="border rounded p-2 h-100">
                            <div class="h4 mb-0">{{raisehand}}</div>
                            <div class="small text-muted">{{#str}} bbb_metric_raisehand, local_unifiedgrader {{/str}}</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg">
                        <div class="border rounded p-2 h-100">
                            <div class="h4 mb-0">{{pollvotes}}</div>
                            <div class="small text-muted">{{#str}} bbb_metric_pollvotes, local_unifiedgrader {{/str}}</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg">
                        <div class="border rounded p-2 h-100">
                            <div class="h4 mb-0">{{emojis}}</div>
                            <div class="small text-muted">{{#str}} bbb_metric_emojis, local_unifiedgrader {{/str}}</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg">
                        <div class="border rounded p-2 h-100">
                            <div class="h4 mb-0">{{durationformatted}}</div>
                            <div class="small text-muted">{{#str}} bbb_metric_duration, local_unifiedgrader {{/str}}</div>
                        </div>
                    </div>
                </div>
            </div>
            {{/activitypoints.sessions}}
        </div>
    </div>
{{/hassummary}}

{{#hasattended}}
    {{^hassummary}}
        {{^callbackenabled}}
        <div class="alert alert-warning mb-0 small" role="status">
            {{#cansiteconfig}}
                {{#str}} bbb_engagement_callback_disabled_admin, local_unifiedgrader {{/str}}
                <a href="{{bbbsettingsurl}}" class="alert-link">
                    {{#str}} bbb_engagement_open_settings, local_unifiedgrader {{/str}}
                </a>
            {{/cansiteconfig}}
            {{^cansiteconfig}}
                {{#str}} bbb_engagement_callback_disabled_teacher, local_unifiedgrader {{/str}}
            {{/cansiteconfig}}
            <div class="mt-2">
                <button type="button" class="btn btn-sm btn-outline-primary"
                        data-action="bbb-refresh-engagement"
                        data-cmid="{{cmid}}">
                    <i class="fa fa-cloud-download me-1" aria-hidden="true"></i>
                    {{#str}} bbb_engagement_scrape_button, local_unifiedgrader {{/str}}
                </button>
                <span class="ms-2 text-muted small" data-region="bbb-refresh-status"></span>
            </div>
        </div>
        {{/callbackenabled}}
        {{#callbackenabled}}
        <div class="alert alert-info mb-0 small" role="status">
            {{#str}} bbb_engagement_pending, local_unifiedgrader {{/str}}
        </div>
        {{/callbackenabled}}
    {{/hassummary}}

    {{^hasrecordings}}
    <div class="alert alert-info mb-0 small" role="status">
        {{#str}} bbb_no_recordings, local_unifiedgrader {{/str}}
    </div>
    {{/hasrecordings}}
{{/hasattended}}

{{^hasrecordings}}
    {{^hasattended}}
    <div class="alert alert-warning mb-0" role="status">
        {{#pix}} i/warning, core {{/pix}}
        <strong class="ms-1">{{#str}} bbb_didnotattend, local_unifiedgrader {{/str}}</strong>
        <div class="small text-muted mt-1">{{#str}} bbb_didnotattend_desc, local_unifiedgrader {{/str}}</div>
    </div>
    {{/hasattended}}
{{/hasrecordings}}

</div>

{{#hasmultiplerecordings}}
<script>
(function() {
    var container = document.querySelector('[data-region="bbb-preview"]');
    if (!container) {
        return;
    }
    var switcher = container.querySelector('[data-region="bbb-recording-switcher"]');
    if (!switcher) {
        return;
    }
    var buttons = switcher.querySelectorAll('button');
    if (!buttons.length) {
        return;
    }

    // When the bbbext_advgrd annotation overlay is active it replaces the plain
    // playback iframe, so there is no in-page src to swap: switching recordings
    // means reloading this preview with the chosen recording id so the server
    // re-renders the overlay (player + its comments) and the matching tiles.
    // When only the plain iframe is present we swap its src in place, no reload.
    var iframe = container.querySelector('[data-region="bbb-recording-iframe"]');
    var aggregate = container.querySelector('[data-region="bbb-tiles-aggregate"]');
    var sessionPanels = container.querySelectorAll('[data-region="bbb-tiles-session"]');

    function setActive(target) {
        buttons.forEach(function(b) {
            b.classList.toggle('active', b === target);
            b.setAttribute('aria-selected', b === target ? 'true' : 'false');
        });
    }

    function showAggregate() {
        if (aggregate) {
            aggregate.classList.remove('d-none');
        }
        sessionPanels.forEach(function(panel) {
            panel.classList.add('d-none');
        });
    }

    function showSession(recordingref) {
        var matched = false;
        sessionPanels.forEach(function(panel) {
            var match = panel.getAttribute('data-recordingref') === recordingref;
            panel.classList.toggle('d-none', !match);
            if (match) {
                matched = true;
            }
        });
        // No engagement data for this recording — fall back to the aggregate
        // view rather than show an empty card.
        if (aggregate) {
            aggregate.classList.toggle('d-none', matched);
        }
    }

    function applyTiles(btn) {
        var ref = btn.getAttribute('data-recordingref') || '';
        if (btn.getAttribute('data-action') === 'bbb-show-aggregate' || !ref) {
            showAggregate();
        } else {
            showSession(ref);
        }
    }

    // Initial tiles state follows the server-selected (active) pill.
    var activeBtn = switcher.querySelector('button.active') || buttons[0];
    applyTiles(activeBtn);

    buttons.forEach(function(btn) {
        btn.addEventListener('click', function() {
            var ref = btn.getAttribute('data-recordingref') || '';
            var isAggregate = btn.getAttribute('data-action') === 'bbb-show-aggregate' || !ref;

            if (iframe) {
                // Plain playback: swap the iframe in place — no reload needed.
                var url = btn.getAttribute('data-recording-url');
                if (url && url !== iframe.getAttribute('src')) {
                    iframe.setAttribute('src', url);
                }
                setActive(btn);
                applyTiles(btn);
                return;
            }

            // Overlay path: already selected? Nothing to do — avoid a needless reload.
            if (btn.classList.contains('active')) {
                return;
            }
            // Reload this preview scoped to the chosen recording so the server
            // rebuilds the annotation overlay and tiles for that session.
            var target = new URL(window.location.href);
            if (isAggregate) {
                target.searchParams.delete('recordingid');
            } else {
                target.searchParams.set('recordingid', ref);
            }
            window.location.href = target.toString();
        });
    });
})();
</script>
{{/hasmultiplerecordings}}

<script>
(function() {
    var fsbtn = document.querySelector('[data-action="bbb-recording-fullscreen"]');
    if (!fsbtn) {
        return;
    }
    fsbtn.addEventListener('click', function() {
        // The BBB recording is rendered inside this iframe; the iframe itself
        // is inside the unifiedgrader page's preview-iframe. Request fullscreen
        // on the OUTER iframe so the whole player area expands. allow=fullscreen
        // is set on both layers so the request propagates correctly.
        var target = null;
        try {
            if (window.parent && window.parent !== window) {
                target = window.parent.document.querySelector('[data-region="preview-iframe"]');
            }
        } catch (e) {
            // Cross-origin guard — fall through to local fullscreen.
        }
        if (!target) {
            target = document.querySelector('[data-region="bbb-recording-iframe"]');
        }
        if (!target) {
            // bbbext_advgrd overlay path - the iframe has been replaced by our own player.
            // Fullscreen the player wrapper so both the <video> and any open feedback
            // callout expand together.
            target = document.querySelector('.advgrd-player-wrapper');
        }
        if (target && target.requestFullscreen) {
            target.requestFullscreen().catch(function() {
                // Some browsers reject without a user-gesture in the grandparent
                // frame; open the playback URL in a new tab as a last resort.
                var iframe = document.querySelector('[data-region="bbb-recording-iframe"]');
                if (iframe) {
                    window.open(iframe.getAttribute('src'), '_blank', 'noopener');
                }
            });
        } else if (target && target.webkitRequestFullscreen) {
            target.webkitRequestFullscreen();
        }
    });
})();
</script>

<script>
(function() {
    var btn = document.querySelector('[data-action="bbb-refresh-engagement"]');
    if (!btn) {
        return;
    }
    var status = document.querySelector('[data-region="bbb-refresh-status"]');
    btn.addEventListener('click', function() {
        var cmid = parseInt(btn.getAttribute('data-cmid'), 10);
        btn.disabled = true;
        status.textContent = '{{#str}} bbb_engagement_scrape_running, local_unifiedgrader {{/str}}';

        // Talk directly to the framework's parent if we're rendered inside an iframe.
        var ajaxFrame = window.parent && window.parent !== window ? window.parent : window;
        ajaxFrame.require(['core/ajax'], function(Ajax) {
            Ajax.call([{
                methodname: 'local_unifiedgrader_refresh_bbb_engagement',
                args: {cmid: cmid}
            }])[0]
            .then(function(result) {
                var msg = '{{#str}} bbb_engagement_scrape_result, local_unifiedgrader {{/str}}';
                msg = msg.replace('{matched}', result.matched)
                         .replace('{unmatched}', result.unmatched)
                         .replace('{recordings}', result.recordings);
                status.textContent = msg;
                // Reload the iframe so the engagement card repopulates.
                setTimeout(function() { window.location.reload(); }, 1500);
            })
            .catch(function(error) {
                status.textContent = (error && error.message) || '{{#str}} bbb_engagement_scrape_error, local_unifiedgrader {{/str}}';
                btn.disabled = false;
            });
        });
    });
})();
</script>
