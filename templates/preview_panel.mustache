{{!
    @template local_unifiedgrader/preview_panel

    Left panel showing submission content preview.

    This template is rendered as a partial of grading_interface.
    Content is populated dynamically by the preview_panel JS component.

    For PDF files, the iframe is replaced by the pdf_viewer component
    which renders via PDF.js and supports annotations.

    Example context (json):
    {}
}}
<div data-region="preview-content" class="h-100 d-flex flex-column">

    {{! Translation controls (assign only; shown by the translation_panel JS
        component when local_nida reports a translation is available). }}
    <div data-region="translation-panel" class="d-none border-bottom bg-white px-3 py-2">
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <button type="button" class="btn btn-sm btn-outline-primary"
                    data-action="translation-toggle">
                <i class="fa fa-language me-1" aria-hidden="true"></i>
                <span data-region="translation-toggle-label"></span>
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary d-none"
                    data-action="translation-parallel">
                <span data-region="translation-parallel-label"></span>
            </button>
            {{! Compact advisory + mixed-language pills and the select-to-comment
                hint. Toggled by translation_panel only while the translated view
                is active — the advisory lives HERE, in the toolbar, so it never
                stacks alert boxes above the document (visual continuity with the
                original viewers). }}
            <span data-region="translation-advisory"
                  class="badge rounded-pill text-bg-warning d-none">
                <i class="fa fa-language me-1" aria-hidden="true"></i>{{#str}} translation_advisory_badge, local_unifiedgrader {{/str}}
            </span>
            <span data-region="translation-mixed"
                  class="badge rounded-pill text-bg-warning d-none">
                {{#str}} translation_mixed_badge, local_unifiedgrader {{/str}}
            </span>
            <span data-region="translation-hint" class="small text-muted d-none">
                {{#str}} segcomment_hint, local_unifiedgrader {{/str}}
            </span>
            {{! Submission-language designation (assign + local_nida). Populated by
                the translation_panel JS; click the code to reveal an override
                selector. Replaces the old marking-panel language-confirm card. }}
            <span data-region="translation-lang" class="d-none ms-auto d-inline-flex align-items-center gap-1">
                <button type="button" class="btn btn-sm btn-light border"
                        data-action="translation-lang-toggle"
                        title="{{#str}} student_language, local_unifiedgrader {{/str}}">
                    <i class="fa fa-flag-o me-1" aria-hidden="true"></i>
                    <span data-region="translation-lang-code" class="fw-semibold text-uppercase"></span>
                    <i class="fa fa-caret-down ms-1 small" aria-hidden="true"></i>
                </button>
                <select data-region="translation-lang-select"
                        class="form-select form-select-sm d-none"
                        style="max-width: 150px;"
                        aria-label="{{#str}} student_language, local_unifiedgrader {{/str}}"></select>
            </span>
        </div>
    </div>

    {{! Translation view (rendered by the translation_panel JS component) }}
    <div data-region="translation-view" class="d-none flex-grow-1 overflow-auto" style="min-height: 0;">
    </div>

    {{! Segment-anchored comments (P2) mount point. The seg_comments JS component
        needs a stable element to attach to, but renders no docked UI: it watches
        the translation view, highlights commented phrases inline, and opens a
        floating composer over the page at the grader's text selection (mirroring
        the pixel annotation composer). It has no visible markup of its own. }}
    <div data-region="seg-comments" class="d-none"></div>

    {{! No submission message }}
    <div data-region="no-submission" class="d-none flex-grow-1 d-flex align-items-center justify-content-center">
        <div class="text-center text-muted">
            <div class="mb-2">{{#pix}} i/warning, core {{/pix}}</div>
            <p>{{#str}} nosubmission, local_unifiedgrader {{/str}}</p>
        </div>
    </div>

    {{! PDF viewer (PDF.js) — shown for PDF files }}
    <div data-region="pdf-viewer-wrapper" class="d-none flex-grow-1" style="min-height: 0;">
        {{> local_unifiedgrader/pdf_viewer }}
    </div>

    {{! Document preview (iframe) — shown for images, text, etc. }}
    <div data-region="document-preview" class="d-none flex-grow-1" style="min-height: 0;">
        <iframe data-region="preview-iframe"
                class="w-100 h-100 border-0"
                src="about:blank"
                allow="autoplay; fullscreen; encrypted-media; picture-in-picture"
                allowfullscreen
                title="{{#str}} previewpanel, local_unifiedgrader {{/str}}">
        </iframe>
    </div>

    {{! Inline annotatable online text (non-translated). preview_panel renders the
        submission's formatted online text here as a paper sheet; the seg_comments
        component decorates it with margin comments and tick/cross/query marks
        anchored by character offset. Shown instead of the iframe for online text. }}
    <div data-region="text-annot-view" class="d-none flex-grow-1 overflow-auto" style="min-height: 0;"></div>

</div>
